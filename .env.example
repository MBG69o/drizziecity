NODE_ENV=development
PORT=3000
SESSION_SECRET=replace_with_strong_random_string

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=samp_user
DB_PASS=change_me
DB_NAME=samp_database

SESSION_TABLE=drizzie_sessions

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-domain.com/auth/discord/callback
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_TICKETS_CHANNEL_ID=your_channel_id

MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_KEY=your_webhook_key

APP_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

JWT_SECRET=replace_with_jwt_secret
JWT_EXPIRES_IN=1d

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM=noreply@drizziecity.com

LOG_LEVEL=info
